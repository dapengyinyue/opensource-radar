# 开源雷达本地开发环境变量
# 复制为 .env 并填入真实值；.env 不提交

# Postgres 连接（brew PG 默认 trust，本机可不带密码）
DATABASE_URL=postgres://localhost:5432/openradar
DATABASE_URL_TEST=postgres://localhost:5432/openradar_test

# HTTP 监听
BIND_ADDR=0.0.0.0:8080

# GitHub token（逗号分隔可多个，用于轮换；MVP 可只填一个）
# 需 public_repo / repo 权限视采集范围而定；search API 用经典 token 即可
GITHUB_TOKENS=

# 管理端手动触发采集的 token
ADMIN_TOKEN=changeme-admin-token

# 日志
RUST_LOG=info,openradar=debug

# 采集周期（秒）
SCHEDULE_GITHUB_SECS=3600
SCHEDULE_HN_SECS=1800
