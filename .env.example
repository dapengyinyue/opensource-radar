# 开源雷达部署环境变量（docker-compose 用）
# 复制为 .env 并填入真实值；.env 不提交。

# ===== PostgreSQL =====
POSTGRES_USER=openradar
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=openradar

# ===== 对外端口（nginx 容器映射）=====
WEB_PORT=8080

# ===== GitHub token（逗号分隔可多个，用于轮换）=====
# 不填则匿名采集（限流严格，建议填一个 classic token）
GITHUB_TOKENS=

# ===== 管理端手动触发采集的 token =====
ADMIN_TOKEN=change-me-admin-token

# ===== 采集周期（秒）=====
SCHEDULE_GITHUB_SECS=3600
SCHEDULE_HN_SECS=1800

# ===== 日志级别 =====
RUST_LOG=info,openradar=debug
